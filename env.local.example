# OpenAI API key (used server-side only by /api/extract)
OPENAI_API_KEY=

# Optional: override the vision model. Defaults to gpt-4o.
# Cheaper / faster: gpt-4o-mini  (less accurate on receipts)
# More capable:    gpt-4.1, gpt-4.1-mini
# OPENAI_MODEL=gpt-4o

# Required for the "Share link" feature. Create a Blob store in your Vercel
# dashboard (Storage -> Blob -> Create) and paste the read-write token here.
# Locally you can also run `vercel env pull` after linking the project.
BLOB_READ_WRITE_TOKEN=

# ── Firebase (push notifications + Google sign-in / account bill history) ──
# Accounts (My bills) use client Auth + Firestore — no Admin env vars needed.
# Push still needs the service account below when you want payment alerts.

# Web Push (client). Firebase Console -> Project Settings -> Cloud Messaging
# -> Web Push certificates -> "Key pair". Public value, safe to expose.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Optional project id override (defaults to web config / split-bill-noti).
FIREBASE_PROJECT_ID=split-bill-noti

# Service account (server, push only). Firebase Console -> Project Settings ->
# Service accounts -> Generate new private key, then copy these fields from the
# downloaded JSON. Keep the private key's literal "\n" escapes and wrap the
# whole value in double quotes.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Also enable in Firebase Console:
#   Authentication -> Sign-in method -> Google
#   Firestore Database + deploy firestore.rules from this repo
#   Authentication -> Settings -> Authorized domains (add your production host)
